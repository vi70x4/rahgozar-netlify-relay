# ── Required ───────────────────────────────────────────────────────────
# Shared secret. Must match the `auth_key` in your rahgozar config.json.
# Generate a strong one with: openssl rand -hex 32
# DO NOT leave the placeholder value in production!
AUTH_KEY="CHANGE_ME_TO_A_STRONG_SECRET"

# ── Optional ──────────────────────────────────────────────────────────
# When "true", bad-auth requests return explicit JSON errors instead of
# decoy HTML. Use during initial setup only; flip to "false" (or unset)
# before sharing the URL publicly.
# DIAGNOSTIC_MODE="false"

# What the `op: "quota"` endpoint reports. Google Apps Script has a hard
# limit of 20,000 URL fetches/day. Netlify has no such limit, but you
# can set this to a reasonable ceiling for compatibility.
# QUOTA_CEILING="100000"

# Comma-separated list of origins allowed to CORS-access this endpoint.
# Leave empty to allow all origins (for browser-based debugging).
# ALLOWED_ORIGINS="https://example.com,https://app.example.com"

# In-memory response cache TTL in milliseconds. When > 0, repeated GET
# requests to the same URL are served from memory instead of fetching
# upstream again. Set to "0" to disable caching.
# CACHE_TTL_MS="60000"
